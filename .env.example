# ==============================================
# School Leaderboard V2 — Environment Variables
# ==============================================
# Copy this file to .env and adjust values for either:
# 1. placeholder/demo mode, or
# 2. live Supabase mode.

# --- Public app config ---
# Placeholder mode stays active when this remains the default placeholder URL.
PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
PUBLIC_SUPABASE_ANON_KEY=placeholder-key

# Required for admin and teacher workflows.
# Set this to your Supabase Edge Functions base URL,
# for example: https://<project-ref>.supabase.co/functions/v1
# If left empty, the site stays in public/demo mode only.
PUBLIC_API_BASE_URL=

# Fallback school name used before admin_settings is configured.
PUBLIC_SCHOOL_NAME=School #45, Fergana

# --- Server secrets ---
# Required for live Supabase mode. Not needed for placeholder mode.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required in all modes.
# The Edge backend uses this on first boot to seed admin_settings.admin_password_hash.
ADMIN_PASSWORD=change-me-admin-password

# Recommended in all modes to avoid the development fallback secret.
JWT_SECRET=change-me-long-random-jwt-secret

# Optional for local frontend-only demos, required for deployed Supabase Edge Functions in production.
# Comma-separated list of allowed browser origins for function CORS checks.
# Example:
# ALLOWED_ORIGINS=https://<your-github-pages-domain>,http://localhost:4321
ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
