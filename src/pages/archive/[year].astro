---
import { listArchiveYears } from '../../lib/archiveData';
import { buildLocaleHref, resolveLocale } from '../../lib/i18n';
import { withBasePath } from '../../lib/utils';

export async function getStaticPaths() {
  return listArchiveYears().map((year) => ({
    params: { year: String(year) },
  }));
}

const { year } = Astro.params;
const locale = resolveLocale(Astro.url);
return Astro.redirect(
  year
    ? buildLocaleHref('/', locale, `year=${year}`)
    : withBasePath('/archive')
);
---
