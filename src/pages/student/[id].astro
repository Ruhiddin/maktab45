---
import Layout from '../../layouts/Layout.astro';
import StudentDetailView from '../../components/StudentDetailView';
import { getFallbackPublicSettings } from '../../lib/publicSettings';
import { listArchiveYears } from '../../lib/archiveData';
import { resolveLocale } from '../../lib/i18n';
import { getStaticStudentRouteParams } from '../../lib/staticPaths';

export async function getStaticPaths() {
  return getStaticStudentRouteParams();
}

const { id } = Astro.params;
const { school_name: schoolName, current_academic_year: academicYear } = getFallbackPublicSettings();
const archiveYears = listArchiveYears();
const locale = resolveLocale(Astro.url);
---

<Layout title="Student" description="View student progress, milestones, and activity." schoolName={schoolName} locale={locale}>
  <StudentDetailView
    client:load
    locale={locale}
    pathname={Astro.url.pathname}
    studentId={id!}
    archiveYears={archiveYears}
    currentAcademicYear={academicYear}
  />
</Layout>
