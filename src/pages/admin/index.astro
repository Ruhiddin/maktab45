---
import Layout from '../../layouts/Layout.astro';
import AdminLogin from '../../components/admin/AdminLogin';
import { getFallbackPublicSettings } from '../../lib/publicSettings';
import { getMessages, resolveLocale } from '../../lib/i18n';

const { school_name: schoolName } = getFallbackPublicSettings();
const locale = resolveLocale(Astro.url);
const m = getMessages(locale);
---

<Layout title={m.public.adminPanel} description={m.public.adminPanelDesc} schoolName={schoolName} noindex locale={locale}>
  <main class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-gray-900 dark:to-gray-800 py-12">
    <AdminLogin client:load locale={locale} />
  </main>
</Layout>
